{
  "name": "sleep-calculator-card",
  "version": "1.1.0",
  "description": "A Home Assistant Lovelace card for calculating optimal sleep and wake-up times based on sleep cycles",
  "author": "Gonzalo Ruiz",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "sleep",
    "sleep-calculator"
  ],
  "scripts": {
    "start": "rollup -c --watch",
    "build": "pnpm run clean && pnpm run rollup",
    "clean": "rm -rf dist sleep-calculator-card.js",
    "rollup": "rollup -c",
    "lint": "eslint src/**/*.ts",
    "serve": "npx serve ."
  },
  "dependencies": {
    "custom-card-helpers": "^2.0.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "rollup": "^4.12.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3"
  }
}
